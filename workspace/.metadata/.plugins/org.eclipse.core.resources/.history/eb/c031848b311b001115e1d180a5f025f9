package rs.ac.bg.etf.pp1.utils;

import org.apache.log4j.Logger;

import rs.ac.bg.etf.pp1.ast.*;
import rs.etf.pp1.symboltable.Tab;
import rs.etf.pp1.symboltable.concepts.*;

import static rs.ac.bg.etf.pp1.constants.ErrorConstants.*;

import java.util.HashMap;
import java.util.Map;

public class SemanticAnalyzerUtils {
	
	private static final Logger LOGGER = Logger.getLogger(SemanticAnalyzerUtils.class);
		
	/**
	 * Logs semantic error to the standard output.
	 * 
	 * @param errorMessage Message to be logged
	 * @param syntaxNode   Node visited when error was found
	 */
	public static void reportError(String errorMessage, SyntaxNode syntaxNode) {
		final int line = syntaxNode != null ? syntaxNode.getLine() : 0;
		LOGGER.error(String.format("%s at line %s.", errorMessage, line));
	}
	
	/**
	 * Opens scope for the object with the given kind, name and type.
	 * 
	 * @param scopeKind Scope kind - Method, Enum, Class, Program
	 * @param scopeName Scope name - unique ident
	 * @param scopeType Scope type
	 * @return Inserted object
	 */
	public static Obj openScope(int scopeKind, String scopeName, Struct scopeType) {
		Obj scope = Tab.insert(scopeKind, scopeName, scopeType);
		Tab.openScope();
		
		LOGGER.info(String.format("Open the [%s] scope.", scopeName));
		return scope;
	}
	
	/**
	 * Chains local symbols and closes the scope.
	 * 
	 * @param scopeObj  Scope to be closed
	 * @param scopeName Scope name
	 */
	public static void closeScope(Obj scopeObj, String scopeName) {
		
		// If the current scope is related to the class, its locals should be stored as part of the scope type
		// In that way, when class object is defined, class locals symbols can be accessed through the object type
		if (scopeObj.getType().getKind() == Struct.Class) {
			scopeObj.getType().setMembers(Tab.currentScope().getLocals());
			
			// Also because virtual table will get address 0, all field addresses have to be moved for 1
			for (Obj member : scopeObj.getType().getMembers()) {
				if (member.getKind() == Obj.Fld) {
					member.setAdr(member.getAdr() + 1);
				}
			}
		} 
		// If scope is not class, chaining local symbols is only needed 
		else {
			Tab.chainLocalSymbols(scopeObj);
		}
			
		Tab.closeScope();
		
		LOGGER.info(String.format("Closed [%s] scope.", scopeName));
	}
	
	/**
	 * Search for the object with the given name in the symbol table.
	 * 
	 * @param object     Found object
	 * @param objectName Expected object name
	 * @return Found object
	 */
	public static Obj findObjectInTheSymbolTable(SyntaxNode object, String objectName) {
		Obj foundObj = Tab.find(objectName);
		
		if (foundObj == Tab.noObj) {
			reportError(String.format(NON_EXISTENT_OBJ_ERROR, objectName), object);
		}
		
		return foundObj;
	}
	
	/**
	 * Inserts constant object to the symbol table. 
	 * 
	 * @param constType Constant Type
	 * @param constVal  Constant Address
	 * @param constName Constant Name
	 * @return Inserted object
	 */
	public static Obj insertConstantToSymbolTable(Struct constType, ConstVal constVal, String constName) {
		Obj constObj = Tab.insert(Obj.Con, constName, constType);
		
		if (constVal instanceof ConstValChar) {
			ConstValChar constValChar = (ConstValChar) constVal;
			constObj.setAdr(constValChar.getCharLiteral());
		} else if (constVal instanceof ConstValBool) {
			ConstValBool constValBool = (ConstValBool) constVal;
			constObj.setAdr(constValBool.getBoolLiteral() ? 1 : 0);
		} else if (constVal instanceof ConstValNumber) {
			ConstValNumber constValNumber = (ConstValNumber) constVal;
			constObj.setAdr(constValNumber.getNumberLiteral());
		}
		
		return constObj;
	}
	
	/**
	 * Checks whether declared type exists or no. If exists, ensures that it can be used as type.
	 * 
	 * @param typeNode Visited AST node
	 * @param typeName Declared type name
	 * @return True if declared type can be used. Otherwise, false
	 */
	public static boolean validateObjectType(SyntaxNode typeNode, String typeName) {
		
		Obj obj = Tab.find(typeName);		

		// Forwarded custom type doesn't exist
		if (obj == Tab.noObj) {			
			reportError(NON_EXISTENT_TYPE_ERROR, typeNode);
			return false;
		}
		
		// Check whether declared type can be used as type
		if (obj.getKind() != Obj.Type) {
			reportError(UNALLOWED_TYPE_ASSIGNMENT_ERROR, typeNode);
			return false;
		}
		
		return true;
		
	}
		
	public static Obj getInstantiatedClassObj(String objectName) {
		return null;
	}
	
	private SemanticAnalyzerUtils() {
		// Private constructor for preventing utils class instantiation
	}
}
