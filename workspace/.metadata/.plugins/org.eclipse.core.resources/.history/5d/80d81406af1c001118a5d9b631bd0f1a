    /* <===========================================================================================================================================> */
	/* <========================================================= Enum declarations ===============================================================> */
    
    /**
     * Defines new enum scope if declared enum name is unique.
     * 
     * @param enumName Visited AST node
     */
    public void visit(EnumName enumName) {
    	String name = enumName.getEnumName();
    	
    	// Check if the name is unique
    	if (doesNameExists(enumName, name)) {
    		enumName.obj = Tab.noObj;
    		semanticErrorFound = true;
    		return;
    	}
    	    	
    	// Define enum scope
    	enumName.obj = openScope(Obj.Type, name, Tab.intType);
    }
    
    /**
     * If enum item name and value are unique, stores enum item in the current scope.
     * 
     * @param enumItem Visited AST node
     */
    public void visit(EnumItem enumItem) {
    	String itemName = enumItem.getEnumItemName();
    	
    	// Check if the name is unique
    	if (doesNameExists(enumItem, itemName)) {
    		enumItem.obj = Tab.noObj;
    		semanticErrorFound = true;
    		return;
    	}
    	    	
    	// If the enum value is not unique, reports error
    	if (enumItem.getEnumItemAssignValue() instanceof EnumValue) {
    		EnumValue enumValue = (EnumValue) enumItem.getEnumItemAssignValue();
    		enumCounter = enumValue.getNumberLiteral();
    		
    		if (presentEnumValues.contains(enumCounter)) {
    			
    			enumItem.obj = Tab.noObj;
    			
    			semanticErrorFound = true;
    			reportError(DOUBLE_ENUM_VALUE_ERROR, enumItem);
    			
    			return;
    		}
    	}
    	
    	enumItem.obj = Tab.insert(Obj.Con, itemName, Tab.intType);
    	enumItem.obj.setAdr(enumCounter++);
    	
    	LOGGER.info(String.format("New enum item [%s] with [%s] value added to the symbol table.", itemName, enumCounter - 1));
    }
    
    /**
     * Closes enum scope and chains its locals.
     * 
     * @param enumDecl Visited AST node
     */
    public void visit(EnumDecl enumDecl) {
    	
    	// Errors reported during enum name declaration node visit - Scope is not opened
    	if (enumDecl.getEnumName().obj == Tab.noObj) {
    		return;
    	}
    	    	
    	closeScope(enumDecl.getEnumName().obj, enumDecl.getEnumName().getEnumName());
        
        // Reset flags for the next enum declaration
        enumCounter = 1;
        presentEnumValues.clear();    
    }
    
