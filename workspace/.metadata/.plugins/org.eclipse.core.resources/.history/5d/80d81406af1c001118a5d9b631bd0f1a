    public void visit(CondFactOptArgDeclaration condFactOptArgDeclaration) { 
    	
    	// Errors reported during visiting term and addop declarations
    	if (condFactOptArgDeclaration.getTermDecl().struct == Tab.noType || 
    		condFactOptArgDeclaration.getAddopTermDeclList().struct == Tab.noType) {
