    /**
     * Resolves mul operations that are allowed only for integer types.
     * 
     * @param termDecl Visited AST node
     */
    public void visit(TermDecl termDecl) { 
    	
    	// Errors reported during visiting termDecl and factorDecl AST nodes
    	if (termDecl.getFactorDecl().struct == Tab.noType || termDecl.getMulopFactorDeclList().struct == Tab.noType) {
    		termDecl.struct = Tab.noType;
    		return;
    	}
    	
    	// If mulopDecl is nullType, no mul operations are present in expressions -> the termDecl type will be the one factor has
    	if (termDecl.getMulopFactorDeclList().struct == Tab.nullType) {
    		termDecl.struct = termDecl.getFactorDecl().struct;
    		return;
    	}
    	
    	// If mulopDecl is present and semantically correct, it will be int type
    	// Because of that, factor also has to be integer
    	if (termDecl.getFactorDecl().struct.getKind() != Struct.Int) {
    		termDecl.struct = Tab.noType;
    		
    		reportError(INVALID_MUL_TYPE_ERROR, termDecl);
    		semanticErrorFound = true;
    		
    		return;
    	}
    	
    	termDecl.struct = Tab.intType;
    }
    
