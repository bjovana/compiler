    /**
     * Resolves function calls. Sent parameters must match function type. If function is non void, at least one safe return must be present.
     * 
     * @param designatorStatementDeclFunction Visited AST node
     */
    public void visit(DesignatorStatementDeclFunction designatorStatementDeclFunction) { 

    	Obj methodObj = designatorStatementDeclFunction.getDesignatorDecl().obj;
    	    	
    	// Errors reported during designator node visit
    	if (methodObj == Tab.noObj) {
    		currentFunctionCallParamTypes.clear();
    		designatorStatementDeclFunction.obj = Tab.noObj;
    		return;
    	}
    	
    	// Ensure that function call is valid
    	if (!validFunctionCall(designatorStatementDeclFunction, methodObj, currentFunctionCallParamTypes.size())) {
    		currentFunctionCallParamTypes.clear();
    		designatorStatementDeclFunction.obj = Tab.noObj;
    		semanticErrorFound = true;
    		return;
    	}
    	   	    
    	// Validate argument types match the function declared parameters
    	if (!validateFunctionCallArguments(designatorStatementDeclFunction, methodObj, currentFunctionCallParamTypes)) {
    		currentFunctionCallParamTypes.clear();
    		designatorStatementDeclFunction.obj = Tab.noObj;
    		semanticErrorFound = true;
    		return;
    	}
    	
    	currentFunctionCallParamTypes.clear();
    	designatorStatementDeclFunction.obj = methodObj;    	
    }
        
    /* Designator statements declaration end */
    
    /* Switch statements declaration */
    
    /**
     * Resolves switch statement options. 
     * 
     * @param switchOptionalStatementDeclarations Visited AST node
     */
    public void visit(SwitchOptionalStatementDeclarations switchOptionalStatementDeclarations) {
    	
    	safeReturnPresent = false;
    	
    	if (duplicateSwitchCase) {
    		return;
    	}
    	
    	if (switchStateCurrentCases.contains(switchOptionalStatementDeclarations.getCase().getNumberLiteral())) {
    		switchOptionalStatementDeclarations.obj = Tab.noObj;
    		duplicateSwitchCase = true;
    		return;
    	}
    	
    	switchStateCurrentCases.add(switchOptionalStatementDeclarations.getCase().getNumberLiteral());
    	switchOptionalStatementDeclarations.obj = new Obj(Obj.Con, "SWITCH CASE", Tab.intType);
    }
    
    /**
     * Resolves switch case statement. Reports error if there are multiple options with the same value or if the option type is not int.
     * 
     * @param statementDeclSwitch Visited AST node
     */
    public void visit(StatementDeclSwitch statementDeclSwitch) {
    	    	
    	// Duplicate cases check
    	if (duplicateSwitchCase) {
    		statementDeclSwitch.obj = Tab.noObj;
    		
    		reportError(SWITCH_DUPLICATE_CASES_ERROR, statementDeclSwitch);
    		semanticErrorFound = true;
    		
    		// Reset error flags for the next switch statement
    		duplicateSwitchCase = false;
    		switchStateCurrentCases.clear();
    		
    		return;
    	}
    	
    	// Expression type error
    	if (statementDeclSwitch.getExprDecl().struct.getKind() != Struct.Int) {
    		statementDeclSwitch.obj = Tab.noObj;
    		
    		reportError(SWITCH_EXPRESSION_INALID_TYPE_ERROR, statementDeclSwitch);
    		semanticErrorFound = true;
    		
    		// Reset error flags for the next switch statement
    		duplicateSwitchCase = false;
    		switchStateCurrentCases.clear();
    		
    		return;
    	}
    	
		// Reset error flags for the next switch statement
		duplicateSwitchCase = false;
		switchStateCurrentCases.clear();
		
		statementDeclSwitch.obj = new Obj(Obj.Con, "SWITCH STATEMENT", Tab.intType);
    	
    }
    
