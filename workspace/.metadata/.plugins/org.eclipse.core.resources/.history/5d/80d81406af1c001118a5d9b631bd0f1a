    	SyntaxNode parent = statementDeclBreak.getParent();
    	
    	while (parent != null && 
    		  !(parent instanceof ForStatementDecl) && 
    	      !(parent instanceof SwitchOptionalStatementDeclList)) {
    		
    		parent = parent.getParent();
    	}
    	
    	if (parent == null) {
    		
    		statementDeclBreak.obj = Tab.noObj;
    		
    		reportError(UNALLOWED_BREAK_CALL_ERROR, statementDeclBreak);
    		semanticErrorFound = true;
    	}
    	
    	statementDeclBreak.obj = new Obj(Obj.Con, "BREAK STATEMENT", Tab.noType);
    }
    
