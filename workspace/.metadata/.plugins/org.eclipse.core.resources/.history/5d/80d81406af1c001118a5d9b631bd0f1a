     * @param designatorDeclIdent Visited AST node
     */
    public void visit(DesignatorDeclIdent designatorDeclIdent) { 
    	
    	Obj designatorObj = findObjectInTheSymbolTable(designatorDeclIdent, designatorDeclIdent.getObjectName());
    	
