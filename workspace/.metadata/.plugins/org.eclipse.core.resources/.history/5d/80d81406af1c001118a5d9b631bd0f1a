    /**
     * Resolves function calls. Forwarded parameters must match function definition.
     * 
     * @param factorDeclFunctionCall Visited AST node
     */
    public void visit(FactorDeclFunctionCall factorDeclFunctionCall) {
    	Obj methodObj = factorDeclFunctionCall.getDesignatorDecl().obj;
    	
    	// Errors reported during designator node visit
    	if (methodObj == Tab.noObj) {
    		currentFunctionCallParamTypes.clear();
    		factorDeclFunctionCall.struct = Tab.noType;
    		return;
    	}
    	
    	if (!validFunctionCall(factorDeclFunctionCall, methodObj, currentFunctionCallParamTypes.size())) {
    		currentFunctionCallParamTypes.clear();
    		factorDeclFunctionCall.struct = Tab.noType;
    		semanticErrorFound = true;
    		return;
    	}
    	
    	// Ensure that called args mach the method declared params
    	if (!validateFunctionCallArguments(factorDeclFunctionCall, methodObj, currentFunctionCallParamTypes)) {
			currentFunctionCallParamTypes.clear();
			factorDeclFunctionCall.struct = Tab.noType;
    		semanticErrorFound = true;
    		return;
    	}
    	    	
    	currentFunctionCallParamTypes.clear();
    	factorDeclFunctionCall.struct = methodObj.getType();
    }
    
