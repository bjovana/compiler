	/**
	 * Checks type validity and duplicate names, then inserts parameter / variable (scalar or array) into symbol table.
	 * 
	 * @param name          Name to be added to the symbol table
	 * @param arrayStruct   Defines whether type is array or not
	 * @param insertionType Defines whether insertion operation is for variable or for parameter
	 * @param syntaxNode    Visited node
	 */
	public void addVariableOrParamToTheSymbolTable(String name, Struct arrayStruct, String insertionType, SyntaxNode syntaxNode) {
		
		// Check if variable / parameter has allowed type
		// No need to report error since that is done during visiting variable type node
		if (invalidVarType) {
			return;
		}

		// Check if forwarded name already exists
		if (doesNameExists(syntaxNode, name)) {
			semanticErrorFound = true;
			return;
		}

		String outputLog = String.format("%s with name [%s] has been added to the symbol table.", insertionType.equals(PARAM_INSERTION) ? "Parameter" : "Variable", name);
		
		Struct typeToInsert = (arrayStruct != Tab.nullType) ? arrayStruct : currentVarType;

	    // Insert symbol
	    Obj obj = Tab.insert(Obj.Var, name, typeToInsert);

	    // If parameter is inserted, its object should have it declared
	    if (insertionType.equals(PARAM_INSERTION)) {
	    	currentParamIndex++;
	        obj.setFpPos(currentParamIndex);
	    } 

	    LOGGER.info(outputLog);
	}
		
