    /**
     * Resolves enum items calls ('.' operator).
     * 
     * @param designatorDeclIdentField Visited AST node
     */
    public void visit(DesignatorDeclIdentField designatorDeclIdentField) {
    	Obj foundObj;
    	
    	String typeName = designatorDeclIdentField.getTypeName();
    	String propertyName = designatorDeclIdentField.getPropertyName();
    	
	    // Verify used type exists
	    foundObj = findObjectInTheSymbolTable(designatorDeclIdentField, typeName);
	    
	    if (foundObj == Tab.noObj) {
	    	semanticErrorFound = true;
	    	designatorDeclIdentField.obj = Tab.noObj;
	    		
	    	return;
	    };
	    	
	    // Verify found object is type kind
	    if (foundObj.getKind() != Obj.Type) {
	    	designatorDeclIdentField.obj = Tab.noObj;
	    		
	    	reportError(INVALID_OPERATOR_FULLSTOP_ERROR, designatorDeclIdentField);
	    	semanticErrorFound = true;
	    		
	    	return;
	    }
	    	    	    
    	for (Obj member : foundObj.getLocalSymbols()) {
    		if (member.getName().equals(propertyName)) {
    			designatorDeclIdentField.obj = member;
    			return;
    		}
    	}
    	    	
    	designatorDeclIdentField.obj = Tab.noObj;
    	semanticErrorFound = true;
    	reportError(String.format(NON_EXISTENT_OBJ_ERROR, designatorDeclIdentField.getPropertyName()), designatorDeclIdentField);
    }
    
    /**
     * Resolves length property call.
     * 
     * <p>
     * Checks if object exists and if object kind is array. If not, reports appropriate error, otherwise sets designatorDeclIdentLength to const int.
     * </p>
     * 
     * @param designatorDeclIdentLength Visited AST node
     */
    public void visit(DesignatorDeclIdentLength designatorDeclIdentLength) { 
    	
    	Obj designatorObj = findObjectInTheSymbolTable(designatorDeclIdentLength, designatorDeclIdentLength.getObjectName());
    	semanticErrorFound = designatorObj == Tab.noObj ? true : semanticErrorFound;
    	
    	// Undefined object
    	if (designatorObj == Tab.noObj || designatorObj == null) {
    		designatorDeclIdentLength.obj = Tab.noObj;    		
    		return;
    	}
    	
    	// Found object is not array
    	if (designatorObj.getType().getKind() != Struct.Array) {
    		designatorDeclIdentLength.obj = Tab.noObj;
    		
    		reportError(LENGTH_CALL_ERROR, designatorDeclIdentLength);
    		semanticErrorFound = true;
    		
    		return;
    	}
    	
    	designatorDeclIdentLength.obj = new Obj(Obj.Var, designatorDeclIdentLength.getObjectName(), Tab.intType);
    	
    	// Needed because object must be seen as array when used during code generation phase
    	designatorDeclIdentLength.obj.setAdr(designatorObj.getAdr());
    	designatorDeclIdentLength.obj.setLevel(designatorObj.getLevel());
    }
    
    /**
     * Resolves array indexing.
     * 
     * @param designatorDeclIdentArrayElemAccess Visited AST node
     */
    public void visit(DesignatorDeclIdentArrayElemAccess designatorDeclIdentArrayElemAccess) { 
    	
    	// Errors reported during expression AST node visit
    	if (designatorDeclIdentArrayElemAccess.getExprDecl().struct == Tab.noType) {
    		designatorDeclIdentArrayElemAccess.obj = Tab.noObj;
    		return;
    	}
    	
    	// Check if ident from input sequence exists
    	Obj identObj = findObjectInTheSymbolTable(designatorDeclIdentArrayElemAccess, designatorDeclIdentArrayElemAccess.getObjectName());
    	
    	if (identObj == Tab.noObj) {
    		semanticErrorFound = true;
    		designatorDeclIdentArrayElemAccess.obj = Tab.noObj;    		
    		return;
    	}
    	
    	// Check if the found object is array
    	if (identObj.getType().getKind() != Struct.Array) {
    		designatorDeclIdentArrayElemAccess.obj = Tab.noObj;
    		
    		reportError(INVALID_ARRAY_ACCESS_ERROR, designatorDeclIdentArrayElemAccess);
    		semanticErrorFound = true;
    		
    		return;
    	}
    	
    	// Check if expression is int type
    	if (designatorDeclIdentArrayElemAccess.getExprDecl().struct.getKind() != Struct.Int) {
    		designatorDeclIdentArrayElemAccess.obj = Tab.noObj;
    		
    		reportError(INVALID_ARRAY_INDEXING_ERROR, designatorDeclIdentArrayElemAccess);
    		semanticErrorFound = true;
    		
    		return;
    	}
    	
    	
    	designatorDeclIdentArrayElemAccess.obj = new Obj(Obj.Var, designatorDeclIdentArrayElemAccess.getObjectName(), identObj.getType().getElemType());
    	
    	// Needed because object must be seen as array when used during code generation phase
    	designatorDeclIdentArrayElemAccess.obj.setAdr(identObj.getAdr());
    	designatorDeclIdentArrayElemAccess.obj.setLevel(identObj.getLevel());
    }

