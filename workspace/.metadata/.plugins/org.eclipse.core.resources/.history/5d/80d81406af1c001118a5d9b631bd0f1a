public class SemanticAnalyzer extends VisitorAdaptor {

	private static final Logger LOGGER = Logger.getLogger(SemanticAnalyzer.class);

	private final Struct boolType;
	private Struct currentConstType, currentVarType;

	private boolean semanticErrorFound = false;
	
	// Used for validations and preventing multiple error reports
	// <========== DON'T FORGET TO RESET WHEN VISITING THE FINAL RULE NODE! ==========> //
	
	private boolean invalidVarType = false, duplicateSwitchCase = false;

	private List<Integer> switchStateCurrentCases = new ArrayList<>();
	private List<Struct> currentFunctionCallParamTypes = new ArrayList<Struct>(); 
	
	private int currentParamIndex = 0;
	private int nVars;
	
	private List<Struct> currentReturnTypes = new ArrayList<>();
	
	private boolean safeReturnPresent = false;
	
	// <==============================================================================> //
	
	// Used for validating enum values //
	// <========== DON'T FORGET TO RESET WHEN VISITING THE FINAL RULE NODE! ==========> //
	
	private int enumCounter = 0;
	private List<Integer> presentEnumValues = new ArrayList<>();
	
	// <==============================================================================> //
	
	private static SemanticAnalyzer semanticAnalyzer = null;
	
	/**
	 * Creates Semantic Analyzer instance. Since semantic analyzer is unique for the whole project, so
	 * its constructor has to be private.
	 *
	 * <p>
	 * Initializes the symbol table and registers the built-in boolean type. 
	 * </p>
	 */
	private SemanticAnalyzer() {
		Tab.init();

		boolType = new Struct(Struct.Bool);
		Tab.insert(Obj.Type, "bool", boolType);

		LOGGER.info("Initialized a Symbol Table.");
	}
		
	/**
	 * Instantiate semantic analyzer instance if one doesn't exist and returns it.
	 * 
	 * @return Semantic Analyze instance
	 */
	public static SemanticAnalyzer getSemanticAnalyzerInstance() {
		
		if (semanticAnalyzer == null) {
			semanticAnalyzer = new SemanticAnalyzer();
		}
		
		return semanticAnalyzer;
	}
	

	/* <========================================================= Program Declaration =========================================================> */

	/**
	 * Processes program name declaration.
	 *
	 * <p>
	 * Creates program object in the symbol table and opens global scope.
	 * </p>
	 *
	 * @param programNameDecl visited AST node
	 */
	public void visit(ProgramNameDecl programNameDecl) {
		programNameDecl.obj = openScope(Obj.Prog, programNameDecl.getProgramName(), Tab.noType);
	}

	/**
	 * Handles program declaration node.
	 *
	 * <p>
	 * Links local symbols to the program object and closes the global scope.
	 * </p>
	 *
	 * @param programDecl visited AST node
	 */

	public void visit(ProgramDecl programDecl) {
		nVars = Tab.currentScope.getnVars();
		closeScope(programDecl.getProgramNameDecl().obj, programDecl.getProgramNameDecl().getProgramName());
		System.out.println("\n\n\n");
	}
	
	/* <=========================================================================================================================================> */
	/* <========================================================= Constants Declaration =========================================================> */

	public void visit(ConstTypeBool constTypeBool) {
		constTypeBool.struct = boolType;
		currentConstType = boolType;
	}

	public void visit(ConstTypeChar constTypeChar) {
		constTypeChar.struct = Tab.charType;
		currentConstType = Tab.charType;
	}

	public void visit(ConstTypeInt constTypeInt) {
		constTypeInt.struct = Tab.intType;
		currentConstType = Tab.intType;
	}

	/**
	 * Resolves user-defined constant type.
	 *
	 * <p>
	 * Checks whether the provided identifier exists and represents a valid type. If valid, assigns it to the node; otherwise reports an error.
	 * </p>
	 *
	 * @param constTypeIdent visited AST node
	 */
	public void visit(ConstTypeIdent constTypeIdent) {

		// Type validations
		Obj typeNode = validateObjectType(constTypeIdent, constTypeIdent.getTypeName());

		// Invalid type
		if (typeNode == Tab.noObj) {
			constTypeIdent.struct = Tab.noType;
			currentConstType = Tab.noType;
			semanticErrorFound = true;
			return;
		}
		
		constTypeIdent.struct = typeNode.getType();
		currentConstType = typeNode.getType();
	}

	public void visit(ConstValBool constValBool) {
		constValBool.struct = boolType;
	}

	public void visit(ConstValChar constValChar) {
		constValChar.struct = Tab.charType;
	}

	public void visit(ConstValNumber constValNumber) {
		constValNumber.struct = Tab.intType;
	}

	/**
	 * Processes additional constant declaration in a list.
	 *
	 * <p>
	 * Checks type compatibility, verifies name uniqueness, inserts constant into symbol table and assigns literal value.
	 * </p>
	 *
	 * @param constDeclarationMul visited AST node
	 */
	public void visit(ConstDeclarationMul constDeclarationMul) {

		// Check if constant type matches the assigned value
		if (!typesAssignable(constDeclarationMul, constDeclarationMul.getConstVal().struct, currentConstType, UNALLOWED_VALUE_ASSIGNED_TO_CONST_ERROR)) {
			semanticErrorFound = true;
			return;
		}

		// Check if the constant name already exists
		String constName = constDeclarationMul.getConstName();

		if (doesNameExists(constDeclarationMul, constName)) {
			semanticErrorFound = true;
			return;
		}

		// Insert constant to a table
		constDeclarationMul.obj = insertConstantToSymbolTable(currentConstType, constDeclarationMul.getConstVal(), constName);
	}

	/**
	 * Processes single constant declaration.
	 *
	 * <p>
	 * Validates assigned value type, checks for duplicate names, inserts constant into symbol table and stores its literal value.
	 * </p>
	 *
	 * @param constDecl visited AST node
	 */
	public void visit(ConstDecl constDecl) {

		// Check if constant type matches the assigned value
		if (!typesAssignable(constDecl, constDecl.getConstVal().struct, constDecl.getConstType().struct, UNALLOWED_VALUE_ASSIGNED_TO_CONST_ERROR)) {
			semanticErrorFound = true;
			return;
		}
		
		// Check if the constant name already exists
		String constName = constDecl.getConstName();

		if (doesNameExists(constDecl, constName)) {
			semanticErrorFound = true;
			return;
		}

		// Insert constant to a table
		constDecl.obj = insertConstantToSymbolTable(constDecl.getConstType().struct, constDecl.getConstVal(), constName);
		
		// This is needed in order to prevent current constant type leak to the next analyze cycles
		currentConstType = null;
	}

