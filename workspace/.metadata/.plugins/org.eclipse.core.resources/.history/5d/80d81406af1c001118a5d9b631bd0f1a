	/* <========================================================= Statement declarations =========================================================> */
    
    /**
     * Resolves read function call that can be called only for <b>basic type variables</b>.
     * 
     * @param statementDeclRead Visited AST node
     */
    public void visit(StatementDeclRead statementDeclRead) { 
    	
    	Obj designatorObj = statementDeclRead.getDesignatorDecl().obj;
    	
    	// Errors reported during designator node visit
    	if (designatorObj == Tab.noObj || designatorObj == null) {
    		statementDeclRead.obj = Tab.noObj;
    		return;
    	}
    	
    	// Check kind of the designator
    	if (designatorObj.getKind() != Obj.Var && designatorObj.getKind() != Obj.Elem) {
    		statementDeclRead.obj = Tab.noObj;
    		
    		reportError(READ_NON_VAR_TYPES_ERROR, statementDeclRead);
    		semanticErrorFound = true;
    		
    		return;
    	}
    	
    	// Check if designator is basic type
    	int typeKind = designatorObj.getType().getKind();
    	
    	if (typeKind != Struct.Int && typeKind != Struct.Char && typeKind != Struct.Bool) {
    		statementDeclRead.obj = Tab.noObj;
    		
    		reportError(READ_INVALID_ARGUMENTS_TYPE_ERROR, statementDeclRead);
    		semanticErrorFound = true;
    		
    		return;
    	}
    	
    	statementDeclRead.obj = designatorObj;
    }
    
    /**
     * Resolves print function that can be called only for <b>basic types</b>.
     * 
     * @param statementDeclPrint Visited AST node
     */
    public void visit(StatementDeclPrint statementDeclPrint) { 
    	
    	// Errors reported during visiting expression AST node
    	if (statementDeclPrint.getExprDecl().struct == Tab.noType) {
    		statementDeclPrint.obj = Tab.noObj;
    		return;
    	}
    	
    	int typeKind = statementDeclPrint.getExprDecl().struct.getKind();
    	
    	if (typeKind != Struct.Int && typeKind != Struct.Char && typeKind != Struct.Bool) {
    		statementDeclPrint.obj = Tab.noObj;
    		
    		reportError(PRINT_ARGUMENT_ERROR, statementDeclPrint);
    		semanticErrorFound = true;
    	}
    	
    }
    
    /* Designator statements declaration */
    
    /**
     * Resolves assignment expressions. Left and right sides of equal sign must be the same type.
     * 
     *  @param designatorStatementDeclAssignment Visited AST node
     */
    public void visit(DesignatorStatementDeclAssignment designatorStatementDeclAssignment) { 
    	
    	Obj designatorObj = designatorStatementDeclAssignment.getDesignatorDecl().obj;
    	Struct exprType = designatorStatementDeclAssignment.getExprDecl().struct;
    	
    	// Errors reported during visiting expression and designator AST nodes
    	if (designatorObj == Tab.noObj || exprType == Tab.noType) {
    		designatorStatementDeclAssignment.obj = Tab.noObj;
    		return;
    	}
    	
    	// Unallowed constant assignments
    	if (designatorStatementDeclAssignment.getDesignatorDecl().obj.getKind() == Obj.Con) {
    		designatorStatementDeclAssignment.obj = Tab.noObj;
    		
    		reportError(ILLEGAL_CONST_ASSIGNMENT_ERROR, designatorStatementDeclAssignment);
    		semanticErrorFound = true;
    		
    		return;
    	}
    	 
    	// Check if types match
    	if (!typesAssignable(designatorStatementDeclAssignment, designatorObj.getType(), exprType, INVALID_ASSIGNMENT_TYPE_ERROR)) {
    		designatorStatementDeclAssignment.obj = Tab.noObj;
    		semanticErrorFound = true;
    		return;
    	}
    	
    	designatorStatementDeclAssignment.obj = designatorObj;
    }
    
    /**
     * Resolves objects increment. Can be called only for integer variables.
     * 
     * 
     * @param designatorStatementDeclIncrement Visited AST node
     */
    public void visit(DesignatorStatementDeclIncrement designatorStatementDeclIncrement) { 
    	
    	Obj designatorObj = designatorStatementDeclIncrement.getDesignatorDecl().obj;
    	
    	// Errors reported during designator node visit
    	if (designatorObj == Tab.noObj) {
    		designatorStatementDeclIncrement.obj = Tab.noObj;
    		return;
    	}
    	
    	// Validate incrementing operation
    	if (!validIncrDectOperation(designatorStatementDeclIncrement, designatorObj.getKind(), designatorObj.getType(), "Incrementing")) {
    		designatorStatementDeclIncrement.obj = Tab.noObj;
    		semanticErrorFound = true;
    		return;
    	}
    	    	
    	designatorStatementDeclIncrement.obj = designatorObj;
    }

