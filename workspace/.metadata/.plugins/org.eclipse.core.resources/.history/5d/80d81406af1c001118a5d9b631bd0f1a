    /* <==============================================================================================================================================> */
	/* <========================================================= Main function declarations =========================================================> */
    
	/**
	 * Opens main function scope or reports error if scope already exists.
	 * 
	 * @param voidMain visited AST node
	 */
    public void visit(VoidMain voidMain) {
    	if (doesNameExists(voidMain, MAIN_SCOPE_NAME)) {
    		voidMain.obj = Tab.noObj;
    		semanticErrorFound = true;
    		return;
    	}
    	    	
    	// Define main scope
    	voidMain.obj = openScope(Obj.Meth, MAIN_SCOPE_NAME, Tab.noType);    	
    	currentParamIndex = 0;
    }
    
    /**
     * Handles main function.
     * 
	 * <p>
	 * Links local symbols to the main object and closes the scope.
	 * </p>
	 * 
	 * @param mainFuncDecl visited AST node
     */
    public void visit(MainFuncDecl mainFuncDecl) { 
    	
    	safeReturnPresent = false;
    	
    	// Errors reported during opening main scope
    	// If the error is reported, main scope is not opened 
    	if (mainFuncDecl.getVoidMain().obj == Tab.noObj) {
    		currentReturnTypes.clear();
    		return;
    	}
    	
    	// Ensure that if return statement is present, expression declaration part is no type
    	for (Struct returnType : currentReturnTypes) {
        	if (returnType != Tab.noType && returnType != Tab.nullType) {
        		currentReturnTypes.clear();
        		
        		mainFuncDecl.getVoidMain().obj = Tab.noObj;
        		
        		reportError(INVALID_RETURN_TYPE_ERROR, mainFuncDecl);
        		semanticErrorFound = true;
        		
        		return;
        	}
    	}

    	
        Obj mainObj = mainFuncDecl.getVoidMain().obj;

        mainObj.setLevel(currentParamIndex);
        LOGGER.info(String.format("[%s] scope level: ", MAIN_SCOPE_NAME) + currentParamIndex);

        currentReturnTypes.clear();
        
        closeScope(mainObj, MAIN_SCOPE_NAME);
    }

    /* <=================================================================================================================================================> */
	/* <========================================================= Custom functions declarations =========================================================> */
    
    /**
     * Opens new scope for declared function name, if the name is unique. Otherwise, throws error.
     * 
     * @param functionNonVoidType Visited AST Node
     */
    public void visit(FunctionNonVoidType functionNonVoidType) {
    	
    	// Check if the name is declared in the current scope
    	if (doesNameExists(functionNonVoidType, functionNonVoidType.getFunctionName())) {
    		functionNonVoidType.obj = Tab.noObj;
    		semanticErrorFound = true;
    		return;
    	}
    	    	
    	// Define non void function scope
    	functionNonVoidType.obj = openScope(Obj.Meth, functionNonVoidType.getFunctionName(), functionNonVoidType.getVarType().struct);
    	currentParamIndex = 0;    	
    } 
    
    /**
     * Opens new scope for declared function name, if the name is unique. Otherwise, throws error.
     * 
     * @param functionVoidType Visited AST Node
     */
    public void visit(FunctionVoidType functionVoidType) {
    	
    	// Throws error if function name already exists
    	if (doesNameExists(functionVoidType, functionVoidType.getFunctionName())) {
    		functionVoidType.obj = Tab.noObj;
    		semanticErrorFound = true;
    		return;
    	}
    	    	
    	// Define void function scope
    	functionVoidType.obj = openScope(Obj.Meth, functionVoidType.getFunctionName(), Tab.noType);
    	currentParamIndex = 0;    	
    }
    
    /**
     * Closes the scope of the custom function.
     * 
     * @param customFuncDecl Visited AST node
     */
    public void visit(CustomFuncDecl customFuncDecl) {
    	
    	// Errors reported during opening custom function scope
    	// If the error is reported, no scopes will be open
    	if (customFuncDecl.getFunctionType().obj == Tab.noObj) {
    		safeReturnPresent = false;
    		currentReturnTypes.clear();
    		return;
    	}
    	
    	String functionName;
    	
    	// Ensure that function has return type if non void
    	if (customFuncDecl.getFunctionType() instanceof FunctionNonVoidType) {
    		
    		FunctionNonVoidType functionNonVoidType = (FunctionNonVoidType) customFuncDecl.getFunctionType();
    		
    		if (currentReturnTypes.isEmpty()) {
				safeReturnPresent = false;
				
    			reportError(MISSING_RETURN_STATEMENT_NON_VOID_FUNCTION_ERROR, customFuncDecl);
    			semanticErrorFound = true;
    			
    			return;
    		}
    		
    		for (Struct returnType : currentReturnTypes) {
    			
        		if (!returnType.assignableTo(functionNonVoidType.getVarType().struct)) {
        			safeReturnPresent = false;
        			currentReturnTypes.clear();
        			
        			reportError(INVALID_RETURN_TYPE_ERROR, customFuncDecl);
            		semanticErrorFound = true;
            		
            		return;
        		}
    			
    		}
    		    		
    		if (!safeReturnPresent) {
    			safeReturnPresent = false;
    			currentReturnTypes.clear();
    			
    			reportError(MISING_SAFE_RETURN_STATEMENT_NON_VOID_FUNCTION_ERROR, customFuncDecl);
    			semanticErrorFound = true;
    			
    			return;
    		}
    		
    		functionName = functionNonVoidType.getFunctionName();
    	}
    	
    	// If the function type is void and return is present, ensure expression declaration is null
    	else {
    		for (Struct returnType : currentReturnTypes) {
        		if (returnType != Tab.noType && returnType != Tab.nullType) {
        			safeReturnPresent = false;
        			currentReturnTypes.clear();
        			reportError(INVALID_RETURN_TYPE_ERROR, customFuncDecl);
            		semanticErrorFound = true;
            		return;
        		}
    		}
    		
    		functionName = ((FunctionVoidType) customFuncDecl.getFunctionType()).getFunctionName();
    	}
    	
    	// Close the function scope
    	Obj functionObj = customFuncDecl.getFunctionType().obj;

        functionObj.setLevel(currentParamIndex);
        LOGGER.info(String.format("[%s] scope level: ", functionName) + currentParamIndex);

        currentReturnTypes.clear();
        safeReturnPresent = false;
        
        closeScope(functionObj, functionName);    	
    }
    
