    /**
     * Resolves continue statement that can be called only within for loop.
     * 
     * @param statementDeclContinue Visited AST node
     */
    public void visit(StatementDeclContinue statementDeclContinue) {
    	
    	SyntaxNode parent = statementDeclContinue.getParent();
    	
    	while (parent != null && !(parent instanceof ForStatementDecl)) {
    		parent = parent.getParent();
    	}
    	
    	if (parent == null) {
    		statementDeclContinue.obj = Tab.noObj;
    		
    		semanticErrorFound = true;
    		reportError(UNALLOWED_CONTINUE_CALL_ERROR, statementDeclContinue);
    		
    		return;
    	}
    	
    	statementDeclContinue.obj = new Obj(Obj.Con, "CONTINUE STATEMENT", Tab.noType);
    }
    
