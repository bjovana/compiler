	}
	
	/**
	 * Process custom variable type declaration.
	 * 
	 * <p>
	 * Checks whether declared type exists. If exists, checks whether found object is stored as type kind in the symbol table. 
	 * If not, reports error. 
	 * </p>
	 * 
	 * @param varTypeIdent Visited AST node
	 */
	public void visit(VarTypeIdent varTypeIdent) { 
				
		// Type validations
		Obj obj = validateObjectType(varTypeIdent, varTypeIdent.getTypeName());
		
		// Invalid type
		if (obj == Tab.noObj) {
			varTypeIdent.struct = Tab.noType;
			currentVarType = Tab.noType;
			invalidVarType = true;
			semanticErrorFound = true;
			
			return;
		}
	
		varTypeIdent.struct = obj.getType();
		currentVarType = obj.getType();
	}
	
