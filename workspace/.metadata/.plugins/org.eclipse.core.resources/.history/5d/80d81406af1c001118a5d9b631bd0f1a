    /**
     * Resolves condition part of the ternary operator.
     * 
     * @param condFactDecl Visited AST node
     */
    public void visit(CondFactDecl condFactDecl) { 
    	
    	// Errors reported during term, addop and condition optional part AST nodes visit
    	if (condFactDecl.getTermDecl().struct == Tab.noType ||
    		condFactDecl.getAddopTermDeclList().struct == Tab.noType ||
    		condFactDecl.getCondFactOptArgDecl().struct == Tab.noType) {
    		
    		condFactDecl.struct = Tab.noType;
    		return;
    	}
    	    	
    	// When relation operator part doesn't exist, term declaration must be boolean type. Addop and optional sign terms must not be present.
    	if (condFactDecl.getCondFactOptArgDecl().struct == Tab.nullType && condFactDecl.getTermDecl().struct.getKind() != boolType.getKind()) {
			
			condFactDecl.struct = Tab.noType;
			
			reportError(INVALID_CONDITION_ERROR, condFactDecl);
    		semanticErrorFound = true;
    		
    		return;
			
		}
		
    	if (condFactDecl.getAddopTermDeclList().struct != Tab.nullType) {
			condFactDecl.struct = Tab.noType;
			
			reportError(INVALID_ARITHMETIC_TYPE_ERROR, condFactDecl);
    		semanticErrorFound = true;
    		
    		return;
    	}
    	
    	if (condFactDecl.getExprOptSignDecl().struct != Tab.nullType) {
			condFactDecl.struct = Tab.noType;
			
			reportError(INVALID_UNARY_MINUS_ERROR, condFactDecl);
    		semanticErrorFound = true;
    		
    		return;
    	}
    	    	
    	condFactDecl.struct = boolType;
    }
    
    /**
     * Resolves ternary operation use.
     * 
     * @param exprDeclarationTernaryOp Visited AST node
     */
    public void visit(ExprDeclarationTernaryOp exprDeclarationTernaryOp) { 
    	
    	// Errors reported during visiting condition and expressions declarations
    	if (exprDeclarationTernaryOp.getConditionDecl().struct == Tab.noType ||
    		exprDeclarationTernaryOp.getExprDecl().struct == Tab.noType ||
    		exprDeclarationTernaryOp.getExprDecl1().struct == Tab.noType) {
    		
    		exprDeclarationTernaryOp.struct = Tab.noType;
    		return;
    	}
    	
    	// Condition part must be bool (no need to check since this part can either be boolean or noType, see CondFactDecl visitor)
    	// Both present expression must be within same type
    	
    	Struct expr1Type = exprDeclarationTernaryOp.getExprDecl().struct;
    	Struct expr2Type = exprDeclarationTernaryOp.getExprDecl1().struct;
    	
    	if (!expr1Type.assignableTo(expr2Type) ||
    		!expr2Type.assignableTo(expr1Type)) {
    		
    		exprDeclarationTernaryOp.struct = Tab.noType;
    		
    		reportError(TERNARY_OPERATOR_ASSIGNMENT_VALUES_MISMATCH_ERROR, exprDeclarationTernaryOp);
    		semanticErrorFound = true;
    		
    		return;
    	}
    	
    	exprDeclarationTernaryOp.struct = expr2Type;
    	
    }
    
    public void visit(CondTermAndPartDeclaration condTermAndPartDeclaration) {
    	
    	// Errors reported during visiting condition factor and expressions parts
    	if (condTermAndPartDeclaration.getCondFactDecl().struct == Tab.noType) {
    		condTermAndPartDeclaration.struct = Tab.noType;
    		return;
    	}
    	
    	condTermAndPartDeclaration.struct = boolType;
    	
    }
    
    public void visit(CondTermAndPartDeclarationEpsilon condTermAndPartDeclarationEpsilon) {
    	condTermAndPartDeclarationEpsilon.struct = Tab.nullType;
    }
    
    public void visit(CondTermDecl condTermDecl) {
    	
    	// Errors reported during condition factor node visit
    	if (condTermDecl.getCondFactDecl().struct == Tab.noType ||
    		condTermDecl.getCondTermAndPartDecl().struct == Tab.noType) {
    		
    		condTermDecl.struct = Tab.noType;
    		return;
    	}
    	
    	condTermDecl.struct = boolType;
    }
    
    public void visit(ConditionOrPartDeclarationEpsilon conditionOrPartDeclarationEpsilon) {
    	conditionOrPartDeclarationEpsilon.struct = Tab.nullType;
    }
    
    public void visit(ConditionOrPartDeclaration conditionOrPartDeclaration) {
    	
    	// Errors reported during condition term node visit
    	if (conditionOrPartDeclaration.getCondTermDecl().struct == Tab.noType) {
    		conditionOrPartDeclaration.struct = Tab.noType;
    		return;
    	}
    	
    	conditionOrPartDeclaration.struct = boolType;
    }
    
    public void visit(ConditionDecl conditionDecl) {
    	
    	// Errors reported during condition term declarations visit
    	if (conditionDecl.getCondTermDecl().struct == Tab.noType ||
    		conditionDecl.getConditionOrPartDecl().struct == Tab.noType) {
    		
    		conditionDecl.struct = Tab.noType;
    		return;
    	}
    	
    	conditionDecl.struct = boolType;
    }
    
    /* Condition expression declaration end */
    
