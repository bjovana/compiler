    /**
     * Resolves expressions.
     * 
     * @param exprDeclaration Visited AST node
     */
    public void visit(ExprDeclaration exprDeclaration) { 
    	
    	// Errors reported during visiting term AST nodes
    	if (exprDeclaration.getTermDecl().struct == Tab.noType || 
    		exprDeclaration.getAddopTermDeclList().struct == Tab.noType) {
    		
    		exprDeclaration.struct = Tab.noType;
    		return;
    	}
    	
    	// If addopTerm is present (not null type), input sequence is arithmetic operation
    	if (exprDeclaration.getAddopTermDeclList().struct != Tab.nullType) {
    		
    		// Check if termDecl is int
    		if (exprDeclaration.getTermDecl().struct.getKind() != Struct.Int) {
    			exprDeclaration.struct = Tab.noType;
    			
    			reportError(INVALID_ARITHMETIC_TYPE_ERROR, exprDeclaration);
    			semanticErrorFound = true;
    			
    			return;
    		}
    		
    		exprDeclaration.struct = Tab.intType; 
    		return;
    	}
    	
    	// If addopDecl is not present, input sequence is not arithmetic operation
    	// Term declaration has not to be int, but unary minus must no be present if term is not int
    	if (exprDeclaration.getTermDecl().struct.getKind() != Struct.Int && exprDeclaration.getExprOptSignDecl().struct != Tab.nullType) {
    		exprDeclaration.struct = Tab.noType;
    		
    		reportError(INVALID_UNARY_MINUS_ERROR, exprDeclaration);
    		semanticErrorFound = true;
    		
    		return;
    	}
    	
    	exprDeclaration.struct = exprDeclaration.getTermDecl().struct;
    	
    }
    
