package rs.ac.bg.etf.pp1;

import java_cup.runtime.Symbol;

%%

%{

	// Generates new symbol (token) with forwarded type
	private Symbol new_symbol(int type) {
		return new Symbol(type, yyline+1, yycolumn);
	}
	
	// Generates new symbol (token) with forwarded type and argument value
	private Symbol new_symbol(int type, Object value) {
		return new Symbol(type, yyline+1, yycolumn, value);
	}

%}

%cup
%line
%column

%xstate COMMENT

%eofval{
	return new_symbol(sym.EOF);
%eofval}

%%

/* Code whiteness - Should be ignored */
" " 									{ }
"\b" 									{ }
"\t" 									{ }
"\r\n" 									{ }
"\f" 									{ }
"\n" 									{ }

/* Comments section - Should be ignored */
"//" 									{ yybegin(COMMENT);}
<COMMENT> . 							{ yybegin(COMMENT); }
<COMMENT> "\r\n" 						{ yybegin(YYINITIAL); }

/* Keywords */
"program"								{ return new_symbol(sym.PROG, yytext()); }
"main"									{ return new_symbol(sym.MAIN, yytext()); }
"const"									{ return new_symbol(sym.CONST, yytext()); }
"int"									{ return new_symbol(sym.INT, yytext()); }
"char"									{ return new_symbol(sym.CHAR, yytext()); }
"bool"									{ return new_symbol(sym.BOOL, yytext()); }
"void"									{ return new_symbol(sym.VOID, yytext()); }
"enum"									{ return new_symbol(sym.ENUM, yytext()); }
"new"									{ return new_symbol(sym.NEW, yytext()); }
"case"									{ return new_symbol(sym.CASE, yytext()); }
"print"									{ return new_symbol(sym.PRINT, yytext()); }
"return" 								{ return new_symbol(sym.RETURN, yytext()); }
"read"   								{ return new_symbol(sym.READ, yytext()); }
"length"								{ return new_symbol(sym.LENGTH, yytext()); }

/* Boolean literals */
"true"  								{ return new_symbol(sym.BOOLCONST, true); }
"false" 								{ return new_symbol(sym.BOOLCONST, false); }

/* Statements */
"if"									{ return new_symbol(sym.IF, yytext()); }
"else"									{ return new_symbol(sym.ELSE, yytext()); }
"break"									{ return new_symbol(sym.BREAK, yytext()); }
"continue"								{ return new_symbol(sym.CONTINUE, yytext()); }
"switch"								{ return new_symbol(sym.SWITCH, yytext()); }

/* Loop */
"for"									{ return new_symbol(sym.FOR, yytext()); }

/* Comparison operators */
"=="  									{ return new_symbol(sym.EQ, yytext()); }
"!="  									{ return new_symbol(sym.NE, yytext()); }
"<="  									{ return new_symbol(sym.LE, yytext()); }
">="  									{ return new_symbol(sym.GE, yytext()); }
"<"   									{ return new_symbol(sym.LT, yytext()); }
">"   									{ return new_symbol(sym.GT, yytext()); }

						
/* Assignment / arithmetical operators */
"++"									{ return new_symbol(sym.INC, yytext()); }
"--"									{ return new_symbol(sym.DEC, yytext()); }
"+" 									{ return new_symbol(sym.PLUS, yytext()); }
"-"										{ return new_symbol(sym.MINUS, yytext()); }
"*"										{ return new_symbol(sym.MUL, yytext()); }
"/"										{ return new_symbol(sym.DIV, yytext()); }
"=" 									{ return new_symbol(sym.EQUAL, yytext()); }
"%" 									{ return new_symbol(sym.MOD, yytext()); }
"+++"									{ return new_symbol(sym.DOUBLE_INC, yytext()); }

/* Logical operators */
"&&"  									{ return new_symbol(sym.AND, yytext()); }
"||" 								 	{ return new_symbol(sym.OR, yytext()); }

/* Ternary operator */
"?"   									{ return new_symbol(sym.QUESTION, yytext()); }
":"   									{ return new_symbol(sym.COLON, yytext()); }

/* Brackets */
"(" 									{ return new_symbol(sym.LPAREN, yytext()); }
")" 									{ return new_symbol(sym.RPAREN, yytext()); }
"{" 									{ return new_symbol(sym.LBRACE, yytext()); }
"}"										{ return new_symbol(sym.RBRACE, yytext()); }
"[" 									{ return new_symbol(sym.SLBRACE, yytext()); }
"]"										{ return new_symbol(sym.SRBRACE, yytext()); }

/* 	Punctuation marks */
";" 									{ return new_symbol(sym.SEMI, yytext()); }
"," 									{ return new_symbol(sym.COMMA, yytext()); }
"."										{ return new_symbol(sym.FULLSTOP, yytext()); }

/* Regular expressions */
'[^']' 									{ return new_symbol(sym.CHARCONST, yytext().charAt(1)); } /* Defines char constants e.g. '1' */
[0-9]+  								{ return new_symbol(sym.NUMBER, Integer.parseInt(yytext())); }
[a-zA-Z][a-zA-Z0-9_]* 					{ return new_symbol (sym.IDENT, yytext()); }

/* Error - Invalid character found in the input sequence */
. { System.err.println("Cannot recognize invalid input: ("+yytext()+") at line "+(yyline+1)); }