package rs.ac.bg.etf.pp1.utils;

import org.apache.log4j.Logger;

import rs.ac.bg.etf.pp1.ast.*;
import rs.etf.pp1.symboltable.Tab;
import rs.etf.pp1.symboltable.concepts.*;

import static rs.ac.bg.etf.pp1.utils.ErrorUtils.*;

public class SemanticAnalyzerUtils {
	
	private static final Logger LOGGER = Logger.getLogger(SemanticAnalyzerUtils.class);
	
	/**
	 * Logs semantic error to the standard output.
	 * 
	 * @param errorMessage Message to be logged
	 * @param syntaxNode   Node visited when error was found
	 */
	public static void reportError(String errorMessage, SyntaxNode syntaxNode) {
		final int line = syntaxNode != null ? syntaxNode.getLine() : 0;
		LOGGER.error(String.format("%s at line %s.", line));
	}
	
	/**
	 * Chains local symbols and closes the scope.
	 * 
	 * @param scopeObj  Scope to be closed
	 * @param scopeName Scope name
	 */
	public static void closeScope(Obj scopeObj, String scopeName) {
		Tab.chainLocalSymbols(scopeObj);
		Tab.closeScope();
		
		LOGGER.info(String.format("Closed %s scope.", scopeName));
	}
	
	/**
	 * Search for the object with the given name in the symbol table.
	 * 
	 * @param object     Found object
	 * @param objectName Expected object name
	 * @return
	 */
	public static Obj findObjectInTheSymbolTable(SyntaxNode object, String objectName) {
		Obj foundObj = Tab.find(objectName);
		
		if (foundObj == Tab.noObj) {
			reportError(String.format(NON_EXISTENT_OBJ_ERROR, objectName), object);
		}
		
		return foundObj;
	}
	
	
	public static Obj insertConstantToSymbolTable(Struct constType, ConstVal constVal, String constName) {
		
	}
	
	private SemanticAnalyzerUtils() {
		// Private constructor for preventing utils class instantiation
	}
}
