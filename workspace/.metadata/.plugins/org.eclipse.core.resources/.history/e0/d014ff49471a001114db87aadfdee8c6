<?xml version="1.0" encoding="UTF-8"?>
<!-- ============================================================
     MicroJava Compiler
     
     Build automation file using Apache Ant.

     Project structure:

     spec/
        mjlexer.lex  → JFlex specification
        mjparser.cup → CUP grammar specification

     src/rs/ac/bg/etf/pp1/
            Yylex.java      	  		(generated by JFlex)
            MJParser.java         		(generated by CUP)
            SemanticAnalyzer.java 		(implemented class used for semantic analysis)
            CodeGenerator.java    		(implemented class used for convertic semanticly correct AST to jvm bytecode)
            CounterVisitor.java			(implemented class used for counting params and variables number of some method)
            sym.java              		(generated by CUP)
            ast/                  		(generated AST classes)

     Main targets:
        delete      → Cleans generated files
        lexerGen    → Generates lexical analyzer
        parserGen   → Generates parser + AST
        repackage   → Fixes AST package paths
        compile     → Compiles entire project
        runObj		→ Executes generated bytecode
   ============================================================ -->
<project name="MJCompiler" default="compile">

	<target name="delete">

		<!-- Remove generated lexer, parser and AST files -->
		<delete>
			<fileset dir="src/rs/ac/bg/etf/pp1">
				<exclude name="Yylex.java" />
				<exclude name="SemanticAnalyzer.java" />
				<exclude name="CodeGenerator.java" />
				<exclude name="CounterVisitor.java" />

				<exclude name="constants/Constants.java" />
				<exclude name="constants/ErrorConstants.java" />
				
				<exclude name="utils/Log4JUtils.java" />
				<exclude name="utils/SemanticAnalyzerUtils.java" />
				<exclude name="utils/CodeGeneratorUtils.java" />
			</fileset>
		</delete>

		<!-- Keep specification files -->
		<delete>
			<fileset dir="spec">
				<exclude name="mjlexer.lex" />
				<exclude name="mjparser.cup" />
			</fileset>
		</delete>
	</target>

	<!-- ========================================= -->
	<!-- Generates lexical analyzer using JFlex   -->
	<!-- ========================================= -->
	<target name="lexerGen" depends="delete">
		<java jar="lib/JFlex.jar" fork="true">
			<arg value="-d" />
			<arg value="./src/rs/ac/bg/etf/pp1" />
			<arg value="spec/mjlexer.lex" />
		</java>
	</target>


	<!-- ========================================= -->
	<!-- Generates parser and AST using CUP       -->
	<!-- ========================================= -->
	<target name="parserGen" depends="delete">
		<java jar="lib/cup_v10k.jar" fork="true">
			<arg value="-destdir" />
			<arg value="src/rs/ac/bg/etf/pp1" />

			<!-- AST generation -->
			<arg value="-ast" />
			<arg value="src.rs.ac.bg.etf.pp1.ast" />

			<!-- Parser class name -->
			<arg value="-parser" />
			<arg value="MJParser" />

			<!-- Debugging options -->
			<arg value="-buildtree" />

			<arg value="spec/mjparser.cup" />
		</java>
	</target>

	<!-- ========================================= -->
	<!-- Fixes package naming in generated AST    -->
	<!-- ========================================= -->
	<target name="repackage" depends="parserGen">
		<!-- Replaces all of the references to the old package name in files in the "src" directory -->
		<replace dir="src" value="rs.ac.bg.etf.pp1.ast" token="src.rs.ac.bg.etf.pp1.ast" summary="true" />
	</target>

	<!-- ========================================= -->
	<!-- Compiles entire project                  -->
	<!-- ========================================= -->
	<target name="compile" depends="repackage">
		<javac srcdir="src/rs/ac/bg/etf/pp1" includeantruntime="false">
			<classpath>
				<pathelement path="lib/JFlex.jar" />
				<pathelement path="lib/cup_v10k.jar" />
				<pathelement path="lib/log4j-1.2.17.jar" />
				<pathelement path="lib/symboltable-1-1.jar" />
				<pathelement path="lib/mj-runtime-1.1.jar" />
			</classpath>
		</javac>
	</target>

	<!-- ========================================= -->
	<!-- Used for running obj fule on MJV          -->
	<!-- ========================================= -->
	<target name="disasm">
		<java classname="rs.etf.pp1.mj.runtime.disasm">
			<arg value="test/program.obj" />
			<classpath>
				<pathelement location="lib/mj-runtime-1.1.jar" />
			</classpath>
		</java>
	</target>

	<target name="runObj" depends="disasm">
		<java classname="rs.etf.pp1.mj.runtime.Run">
			<arg value="test/program.obj" />
			<classpath>
				<pathelement location="lib/mj-runtime-1.1.jar" />
			</classpath>
		</java>
	</target>

</project>
