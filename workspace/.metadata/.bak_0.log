package rs.ac.bg.etf.pp1.utils;

import org.apache.log4j.Logger;

import rs.ac.bg.etf.pp1.ast.*;

public class SemanticAnalyzerUtils {
	
	private static final Logger LOGGER = Logger.getLogger(SemanticAnalyzerUtils.class);
	
	/**
	 * Logs semantic error to the standard output.
	 * 
	 * @param errorMessage Message to be logged
	 * @param syntaxNode   Node visited when error was found
	 */
	public static void reportError(String errorMessage, SyntaxNode syntaxNode) {
		final int line = syntaxNode != null ? syntaxNode.getLine() : 0;
		LOGGER.error(String.format("%s at line %s.", line));
	}
	
	public static void closeScope()
	
	private SemanticAnalyzerUtils() {
		// Private constructor for preventing utils class instantiation
	}
}

